{
  "routes": [
    {
      "src": "^/assets/(.*)$",
      "dest": "/public/assets/$1"
    },
    {
      "src": "^/favicon.png$",
      "dest": "/public/favicon.png"
    },
    {
      "src": "^/opengraph.jpg$",
      "dest": "/public/opengraph.jpg"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
